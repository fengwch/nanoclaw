# NanoClaw Host 进程镜像（用于 K8s Deployment）
# 仅包含 Host 端 Node 应用，不包含 Agent 容器镜像；Agent 镜像需单独构建（见同目录 Dockerfile）
FROM node:22-slim

WORKDIR /app

# 依赖
COPY package*.json ./
RUN npm ci --omit=dev

# 构建产物与必要文件（请在项目根目录执行 build：docker build -f container/Dockerfile.host .）
COPY dist ./dist
COPY container/skills ./container/skills
COPY groups ./groups

# store/data/logs 在 K8s 中由 PVC 挂载；groups 也可用 PVC 覆盖
RUN mkdir -p store data logs

# 凭证代理 3001、可选 HTTP 3000
EXPOSE 3001 3000

CMD ["node", "dist/index.js"]
